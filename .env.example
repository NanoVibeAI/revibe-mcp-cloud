NODE_ENV=development
PORT=8000
APP_NAME="Revibe MCP Cloud"
MCP_SERVER_NAME="revibe-mcp-cloud"
MCP_SERVER_VERSION="0.1.0"

# Storage Configuration
# STORAGE_PROVIDER options: "supabase" (default), "vercel_blob", "local"
STORAGE_PROVIDER="supabase"
LOCAL_STORAGE_PATH="./storage/artifacts"

# Supabase Storage Configuration (required if using supabase provider)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"
SUPABASE_STORAGE_BUCKET="revibe-components"
SUPABASE_DB_SCHEMA="apps_revibe"

# Vercel Blob Configuration (required if using vercel_blob provider)
# Get this from: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Optional extra path prefix inside the storage root. Leave empty to store at /<bucket>/components.
STORAGE_BASE_PATH=""

# Embeddings and discovery
EMBEDDINGS_MODEL="sentence-transformers/all-MiniLM-L6-v2"
MAX_DISCOVERY_RESULTS=10
DISCOVERY_SCORE_THRESHOLD=0.5

# Ranking weights (sum should = 1.0)
RANK_WEIGHT_SIMILARITY=0.4
RANK_WEIGHT_QUALITY=0.3
RANK_WEIGHT_POPULARITY=0.3
